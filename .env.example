# Optional workspace and prompt overrides.
# If omitted, Protocol Monk uses the current working directory and the packaged system prompt.
WORKSPACE=.
# SYSTEM_PROMPT_PATH=/absolute/path/to/custom_system_prompt.txt
LOG_LEVEL=INFO

# Provider selection: ollama | openrouter
LLM_PROVIDER=ollama

# Active model for this session (resolved from provider model map)
ACTIVE_MODEL_ALIAS=

# Runtime UI backend: rich | cli
PROTOCOL_MONK_UI=rich
PROTOCOL_MONK_SKIP_WIZARD=0

# Ollama configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_API_KEY=

# OpenRouter configuration
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
# Optional override for a user-managed OpenRouter model map.
# By default, the packaged example map is used.
# OPENROUTER_MODELS_JSON_PATH=.protocol_monk/openrouter_models.json

# Discovery and runtime controls
FORCE_MODEL_DISCOVERY=false
PRUNING_THRESHOLD=0.8
TOOL_TIMEOUT=60

# Session transcript retention
TRACE_MAX_SESSIONS=200
TRACE_MAX_TOTAL_MB=250
